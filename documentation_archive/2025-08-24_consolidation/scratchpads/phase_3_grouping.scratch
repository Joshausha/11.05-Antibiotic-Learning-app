## DOM Structure for Group Organization

```html
<div class="northwestern-group-organization">
  <!-- Group headers with medical context -->
  <div class="group-headers">
    <div class="group-header group-header--beta-lactams" data-group="betaLactams">
      <h3 class="group-title">β-Lactams</h3>
      <p class="group-context">Cell Wall Synthesis Inhibitors</p>
      <div class="group-stats">
        <span class="antibiotic-count">15 antibiotics</span>
        <span class="class-count">4 classes</span>
        <span class="generation-range">1st-5th gen</span>
      </div>
      <button class="group-toggle" aria-expanded="true">
        <span class="sr-only">Toggle β-Lactam group</span>
      </button>
    </div>
  </div>
  
  <!-- Group boundaries overlay -->
  <div class="group-boundaries-overlay">
    <div class="group-boundary group-boundary--beta-lactams" 
         style="grid-area: 1/1/3/4">
      <div class="boundary-border"></div>
      <div class="boundary-background"></div>
    </div>
  </div>
  
  <!-- Group connection lines -->
  <svg class="group-connections" viewBox="0 0 100 100">
    <g class="connection-lines">
      <line class="generation-connection" 
            x1="10" y1="10" x2="20" y2="10" 
            data-from="cephalosporin-1st" 
            data-to="cephalosporin-2nd"/>
    </g>
  </svg>
  
  <!-- Group statistics panels -->
  <div class="group-statistics-panel" data-group="betaLactams">
    <div class="coverage-summary">
      <div class="coverage-item">
        <span class="pathogen">MRSA</span>
        <div class="coverage-bar">
          <div class="coverage-fill" style="width: 20%"></div>
        </div>
        <span class="coverage-value">Low</span>
      </div>
    </div>
  </div>
</div>
```

