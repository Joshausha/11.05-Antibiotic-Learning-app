    props: ['connections', 'visible'],
    features: ['Generation relationships', 'Mechanism similarities', 'Class relationships']
  }
};
```

### Medical Grouping Logic Algorithms

#### Drug Class Classification System
```javascript
const MedicalClassification = {
  classifyByMechanism: (antibiotics) => {
    const mechanismGroups = {
      cellWall: antibiotics.filter(ab => ab.cellWallActive === true),
      proteinSynthesis: antibiotics.filter(ab => 
        ['Aminoglycoside', 'Macrolide', 'Lincosamide', 'Chloramphenicol'].includes(ab.class)
      ),
      dnaRNA: antibiotics.filter(ab => 
        ['Quinolone', 'Fluoroquinolone'].includes(ab.class) || ab.name === 'Metronidazole'
      ),
      specialized: antibiotics.filter(ab => 
        ['Glycopeptide', 'Lipopeptide', 'Oxazolidinone'].includes(ab.class)
      )
    };
    return mechanismGroups;
  },

  classifyByGeneration: (antibiotics, drugClass) => {
    return antibiotics
      .filter(ab => ab.class === drugClass)
      .sort((a, b) => {
        const genOrder = {
          '1st generation': 1, '2nd generation': 2, '3rd generation': 3,
          '4th generation': 4, '5th generation': 5,
          'Natural': 1, 'Penicillinase-resistant': 2, 'Extended-spectrum': 3
        };
        return (genOrder[a.generation] || 999) - (genOrder[b.generation] || 999);
      });
  },

  classifyByRoute: (antibiotics) => {
    const routeGroups = {
      oral: antibiotics.filter(ab => ab.route.includes('PO')),
      iv: antibiotics.filter(ab => ab.route.includes('IV')),
      both: antibiotics.filter(ab => ab.route.includes('PO') && ab.route.includes('IV'))
    };
    return routeGroups;
  }
};
```

#### Group Statistics Calculation
```javascript
const GroupStatistics = {
  calculateCoverageSummary: (groupAntibiotics) => {
    const coverageStats = {
      MRSA: 0, VRE_faecium: 0, anaerobes: 0, atypicals: 0,
      pseudomonas: 0, gramNegative: 0, MSSA: 0, enterococcus_faecalis: 0
    };

    groupAntibiotics.forEach(antibiotic => {
      Object.keys(antibiotic.northwesternSpectrum).forEach(pathogen => {
        coverageStats[pathogen] += antibiotic.northwesternSpectrum[pathogen];
      });
    });

    // Calculate averages
    const avgCoverage = {};
    Object.keys(coverageStats).forEach(pathogen => {
      avgCoverage[pathogen] = coverageStats[pathogen] / groupAntibiotics.length;
    });

    return avgCoverage;
  },

  calculateGroupMetrics: (groupAntibiotics) => {
    return {
      totalCount: groupAntibiotics.length,
      routeDistribution: {
        oral: groupAntibiotics.filter(ab => ab.route.includes('PO')).length,
        iv: groupAntibiotics.filter(ab => ab.route.includes('IV')).length,
        both: groupAntibiotics.filter(ab => 
          ab.route.includes('PO') && ab.route.includes('IV')
        ).length
      },
      generationDistribution: groupAntibiotics.reduce((acc, ab) => {
        if (ab.generation) {
          acc[ab.generation] = (acc[ab.generation] || 0) + 1;
        }
        return acc;
      }, {}),
      resistancePatterns: groupAntibiotics.map(ab => ab.resistance).filter(Boolean)
    };
  }
};
```

### Visual Design System

#### Group Visual Hierarchy
```css
.group-organization {
  --group-beta-lactam: #e3f2fd;
  --group-protein: #f3e5f5;
  --group-dna: #e8f5e8;
  --group-specialized: #fff3e0;
  
  --border-beta-lactam: #1976d2;
  --border-protein: #7b1fa2;
  --border-dna: #388e3c;
  --border-specialized: #f57c00;
  
  --accent-beta-lactam: #0d47a1;
  --accent-protein: #4a148c;
  --accent-dna: #1b5e20;
  --accent-specialized: #e65100;
}
```

#### Responsive Group Headers
```css
.group-header {
  /* Mobile: Compact headers */
  @media (max-width: 767px) {
    padding: 8px 12px;
    font-size: 0.875rem;
    .group-stats { display: none; }
  }
  
  /* Tablet: Moderate detail */
  @media (min-width: 768px) and (max-width: 1023px) {
    padding: 12px 16px;
    font-size: 1rem;
    .group-stats { display: block; }
  }
  
  /* Desktop: Full detail */
  @media (min-width: 1024px) {
    padding: 16px 20px;
    font-size: 1.125rem;
    .group-stats { display: flex; }
  }
}
```

