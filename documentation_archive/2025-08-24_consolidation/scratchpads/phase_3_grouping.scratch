const FilteringIntegration = {
  // Group-based filtering functions
  filterByGroup: (groupKey, antibiotics) => {
    return antibiotics.filter(ab => ab.spatialGroup === groupKey);
  },
  
  filterByMechanism: (mechanism, groups) => {
    const mechanismMap = {
      cellWall: ['betaLactams'],
      proteinSynthesis: ['proteinSynthesis'],
      dnaRNA: ['dnaGyrase'],
      specialized: ['specialized']
