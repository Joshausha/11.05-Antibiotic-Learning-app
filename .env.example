# Environment Configuration for Antibiotic Learning App
# Copy this file to .env and configure the values below

# PubMed API Configuration
# Optional but recommended for higher rate limits
# Get your API key from: https://www.ncbi.nlm.nih.gov/account/settings/
REACT_APP_PUBMED_API_KEY=your_pubmed_api_key_here

# CDC Data API Configuration
# For accessing antibiotic resistance surveillance data
REACT_APP_CDC_API_KEY=your_cdc_api_key_here
REACT_APP_CDC_BASE_URL=https://data.cdc.gov/resource/

# Feature Flags
# Enable/disable specific features during development
REACT_APP_ENABLE_RESEARCH_INTEGRATION=true
REACT_APP_ENABLE_CDC_DATA=false
REACT_APP_ENABLE_ADVANCED_ANALYTICS=true

# Development Configuration
REACT_APP_DEBUG_MODE=false
REACT_APP_LOG_LEVEL=warn

# Medical Data Configuration
REACT_APP_CACHE_DURATION_HOURS=24
REACT_APP_MAX_SEARCH_RESULTS=20
REACT_APP_DEFAULT_DATE_RANGE_YEARS=3

# API Rate Limiting
REACT_APP_API_RATE_LIMIT_PER_MINUTE=60
REACT_APP_ENABLE_API_CACHING=true

# Analytics Configuration
REACT_APP_ENABLE_USAGE_ANALYTICS=false
REACT_APP_ANALYTICS_ENDPOINT=

# Security Configuration
# Only enable in development environments
REACT_APP_DISABLE_HTTPS_REQUIREMENTS=false
REACT_APP_ENABLE_CORS_DEV_MODE=false